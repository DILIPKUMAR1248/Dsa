import java.util.*;

public class Main {
    static int maximum_occurrence(int arr[], int n) {
        //Write code here
        Arrays.sort(arr);
        int maxcount=1;
        int count=1;
        int ans=arr[0];
        for(int i=1;i<n;i++){
            if(arr[i]==arr[i-1]){
                count++;
            }else{
                count=1;
            }
            if(count>maxcount){
                maxcount=count;
                ans=arr[i];
            }
        }
         return ans;
    }
    public static void main(String args[]) {
        int n;
        Scanner sc = new Scanner(System.in);
        n = sc.nextInt();
        int[] arr = new int[n];
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }
        System.out.print(maximum_occurrence(arr, n));

    }
}
