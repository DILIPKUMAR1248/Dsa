class Solution {

    // Find index of max digit from i to end
    public static int findMax(int i, ArrayList<Integer> list) {
        int maxIndex = i;
        for (int j = i; j < list.size(); j++) {
            if (list.get(j) >= list.get(maxIndex)) {
                maxIndex = j;
            }
        }
        return maxIndex;
    }

    public int maximumSwap(int num) {

        // Step 1: Store digits in ArrayList
        ArrayList<Integer> list = new ArrayList<>();
        int temp = num;
        while (temp > 0) {
            list.add(0, temp % 10);  // insert at beginning to keep order
            temp /= 10;
        }

        // Step 2: Try to find best swap
        for (int i = 0; i < list.size()-1; i++) {
            int maxIndex = findMax(i + 1, list);
            if (list.get(i) < list.get(maxIndex)) {
                // Swap
                int t = list.get(i);
                list.set(i, list.get(maxIndex));
                list.set(maxIndex, t);

                // Convert ArrayList back to number
                int result = 0;
                for (int d : list) {
                    result = result * 10 + d;
                }
                return result;
            }
        }

        return num;  // already max
    }
    }
