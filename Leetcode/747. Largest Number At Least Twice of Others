class Solution {
    public int dominantIndex(int[] nums) {
        int max=nums[0];
        int maxIndex=0;
        for(int i=1;i<nums.length;i++){
            if(nums[i]>max){
                max=nums[i];
                maxIndex=i;
            }

        }
        int n=nums.length;
        int i=0;
        while(i<n){
            if(i!=maxIndex && max<nums[i]*2){
                return -1;
            }
            
          i++;
        }
        return maxIndex;
    }
}
