class Solution {
    public int maxChunksToSorted(int[] nums) {
        int max=Integer.MIN_VALUE;
        int totalchunks=0;
        for(int i=0;i<nums.length;i++)
         {
            max=Math.max(nums[i],max);
                if(i==max){
                    totalchunks++;
                }
            
         }
         return totalchunks;        
    }
}
